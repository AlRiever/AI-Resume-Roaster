# ============================================================
# Resume Roaster AI — Environment Variables (v1.4.0)
# ============================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed or shared.
# ============================================================

# ── OpenRouter (AI provider) ───────────────────────────────
# Free key from: https://openrouter.ai/  →  Keys
# Used to access Gemma 4 26B A4B (free tier).
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Supabase (public — safe in browser) ────────────────────
# Found in your Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# ── Supabase (SECRET — server only) ────────────────────────
# Bypasses Row-Level Security. Treat like a database password.
# The lack of NEXT_PUBLIC_ prefix is load-bearing — it keeps this
# key out of the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-here

# ============================================================
# Auth setup checklist (v1.4.0+) — do this in the Supabase dashboard:
#
#   1. Authentication → Providers → Email: ENABLED
#   2. Authentication → Providers → Email → "Confirm email": ON
#   3. Authentication → URL Configuration:
#        Site URL: http://localhost:3000  (or your prod URL)
#        Redirect URLs: include http://localhost:3000/auth/callback
#   4. Authentication → Emails: configure SMTP (or use the built-in
#      Supabase sender for development — limited to 3 emails/hour)
#   5. SQL Editor: run supabase/migrate-v1.4.0-auth.sql once
# ============================================================
